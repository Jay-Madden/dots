{
  "$schema": "https://opencode.ai/config.json",
  "plugin": [
    "./plugin/no-code-comments.ts"
  ],
  "lsp": true,
  "autoupdate": true,
  "permission": {
    "edit": "ask",
    "write": "ask",
    "patch": "ask",
    "bash": {
      "*": "ask",
      "ls": "allow",
      "ls *": "allow",
      "cat *": "allow",
      "head *": "allow",
      "tail *": "allow",
      "grep *": "allow",
      "rg *": "allow",
      "fd *": "allow",
      "find *": "allow",
      "tree": "allow",
      "tree *": "allow",
      "wc *": "allow",
      "stat *": "allow",
      "file *": "allow",
      "pwd": "allow",
      "which *": "allow",
      "echo *": "allow",
      "diff *": "allow",
      "git status": "allow",
      "git status *": "allow",
      "git diff": "allow",
      "git diff *": "allow",
      "git log": "allow",
      "git log *": "allow",
      "git show": "allow",
      "git show *": "allow",
      "git branch": "allow",
      "git branch *": "allow"
    },
    "webfetch": "allow"
  },
  "provider": {
    "inference.nvidia.com": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "inference.nvidia.com",
      "options": {
        "baseURL": "https://inference-api.nvidia.com/v1",
        "apiKey": "{env:INFERENCE_HUB_API_KEY}"
      },
      "models": {
        "aws/anthropic/claude-opus-4-5": {
          "name": "claude opus 4.5",
          "limit": {
            "context": 200000,
            "output": 65536
          }
        },
        "aws/anthropic/bedrock-claude-opus-4-6": {
          "name": "claude opus 4.6",
          "limit": {
            "context": 200000,
            "output": 65536
          }
        },
        "aws/anthropic/bedrock-claude-opus-4-7": {
          "name": "claude opus 4.7"
          // "limit": {
          //   "context": 200000,
          //   "output": 65536
          // }
        },
        "aws/anthropic/bedrock-claude-opus-4-8": {
          "name": "claude opus 4.8",
          "options": {
            "thinking": {
              "type": "adaptive"
            },
            "output_config": {
              "effort": "medium"
            }
          }
        },
        "nvidia/nvidia/nemotron-3-super-v3": {
          "name": "nemotron 3 super v3",
          "limit": {
            "context": 200000,
            "output": 4096
          }
        }
      }
    }
  }
}

