{
  "$schema": "https://opencode.ai/config.json",
  "plugin": [
    "./plugin/no-code-comments.ts"
  ],
  "lsp": true,
  "autoupdate": true,
  "permission": {
    "edit": "ask",
    "write": "ask",
    "patch": "ask",
    "bash": {
      "*": "ask",
      "ls": "allow",
      "ls *": "allow",
      "cat *": "allow",
      "head *": "allow",
      "tail *": "allow",
      "grep *": "allow",
      "rg *": "allow",
      "fd *": "allow",
      "find *": "allow",
      "tree": "allow",
      "tree *": "allow",
      "wc *": "allow",
      "stat *": "allow",
      "file *": "allow",
      "pwd": "allow",
      "which *": "allow",
      "echo *": "allow",
      "diff *": "allow",
      "git status": "allow",
      "git status *": "allow",
      "git diff": "allow",
      "git diff *": "allow",
      "git log": "allow",
      "git log *": "allow",
      "git show": "allow",
      "git show *": "allow",
      "git branch": "allow",
      "git branch *": "allow"
    },
    "webfetch": "allow"
  }
}

